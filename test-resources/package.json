{
    "name": "test-resources",
    "scripts": {
        "lint": "eslint .",
        "lint:fix": "eslint . --fix",
        "sam:build": "npm run sam:validate && sam build --template infrastructure/template.yaml --cached --parallel",
        "sam:validate": "cd infrastructure && sam validate && sam validate --lint",
        "test": "npm run unit --",
        "test:integration": "vitest run --config integration-tests/vitest.config.ts --no-file-parallelism",
        "test:coverage": "npm run unit -- --coverage",
        "unit": "export POWERTOOLS_DEV=true && vitest run --exclude 'integration-tests/**'",
        "unit:logs": "vitest run"
    },
    "dependencies": {
        "@aws-lambda-powertools/commons": "2.33.0",
        "@aws-lambda-powertools/logger": "2.33.0",
        "@aws-lambda-powertools/parameters": "2.33.0",
        "@aws-sdk/client-cloudformation": "3.1048.0",
        "@aws-sdk/client-kms": "3.1048.0",
        "@aws-sdk/client-sns": "^3.1048.0",
        "@aws-sdk/client-ssm": "3.1048.0",
        "@govuk-one-login/data-vocab": "2.0.2",
        "@govuk-one-login/data-vocab-schemas": "2.0.2",
        "@middy/core": "4.7.0",
        "ajv": "8.20.0",
        "ajv-formats": "3.0.1",
        "aws-sdk-client-mock": "4.1.0",
        "ecdsa-sig-formatter": "1.0.11",
        "esbuild": "0.28.0",
        "jose": "6.2.3"
    },
    "devDependencies": {
        "@aws-sdk/client-dynamodb": "3.1048.0",
        "@aws-sdk/credential-providers": "3.1048.0",
        "@aws-sdk/types": "3.973.8",
        "@types/aws-lambda": "^8.10.161",
        "@typescript-eslint/eslint-plugin": "^6.11.0",
        "@typescript-eslint/parser": "^6.11.0",
        "@vitest/coverage-v8": "4.1.6",
        "aws-sigv4-fetch": "4.4.1",
        "eslint": "^8.53.0",
        "eslint-config-prettier": "^9.0.0",
        "eslint-plugin-prettier": "^5.0.1",
        "prettier": "^3.8.3",
        "ts-node": "^10.9.2",
        "typescript": "^5.9.3",
        "vitest": "4.1.6"
    }
}
