{
    "name": "di-ipv-common-lambdas",
    "type": "module",
    "scripts": {
        "lint": "eslint .",
        "lint:fix": "eslint . --fix",
        "unit": "vitest run --exclude tests/unit/handlers/contract/*.test.ts",
        "test": "npm run unit --",
        "test:coverage": "vitest run --coverage",
        "sam:validate": "cd ../../infrastructure/lambda && sam validate && sam validate --lint",
        "sam:build": "npm run sam:validate && sam build --template ../../infrastructure/lambda/template.yaml --cached --parallel",
        "start:contract": "cd tests/unit/handlers/contract && tsx ./app.ts",
        "test:contract": "wait-on tcp:127.0.0.1:3000; vitest run --config vitest.config.contract.ts --no-file-parallelism",
        "test:contract:ci": "npm-run-all -p -r start:contract test:contract",
        "deploy": "../../deploy.sh",
        "compile": "tsc"
    },
    "dependencies": {
        "@aws-lambda-powertools/logger": "2.33.0",
        "@aws-lambda-powertools/metrics": "2.33.0",
        "@aws-lambda-powertools/parameters": "2.33.0",
        "@aws-sdk/client-dynamodb": "3.1048.0",
        "@aws-sdk/client-kms": "3.1048.0",
        "@aws-sdk/client-sqs": "3.1048.0",
        "@aws-sdk/client-ssm": "3.1048.0",
        "@aws-sdk/credential-providers": "3.1048.0",
        "@aws-sdk/lib-dynamodb": "3.1048.0",
        "@govuk-one-login/cri-audit": "1.0.3",
        "@govuk-one-login/cri-logger": "1.0.1",
        "@govuk-one-login/cri-metrics": "1.0.1",
        "@middy/core": "4.7.0",
        "aws-sigv4-fetch": "4.4.1",
        "esbuild": "0.28.1",
        "jose": "6.2.3",
        "zod": "4.4.3"
    },
    "devDependencies": {
        "@pact-foundation/pact": "16.4.0",
        "@types/aws-lambda": "8.10.161",
        "@types/express": "^4.17.25",
        "@types/node": "22.19.19",
        "express": "^4.22.2",
        "express-rate-limit": "^7.5.1",
        "npm-run-all2": "^9.0.2",
        "tsx": "4.22.1",
        "wait-on": "8.0.5"
    }
}
